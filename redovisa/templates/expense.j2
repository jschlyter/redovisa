<html>

<head>
<title>Redovisa</title>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="stylesheet" href="/static/redovisa.css">
<link rel="stylesheet" href="/static/buttons.css">
<link rel="icon" href="/static/favicon.ico">
<script type="text/javascript" src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script type="text/javascript" src="/static/functions.js"></script>
</head>

{% set pattern_amount = "^\\d+(([\\.,]\\d{2})?)$" %}
{% set pattern_account = "^\\d{4}[\\d\\-,\\s]+$" %}

<body>
<h1>Redovisa utlägg för {{ organisation }}</h1>

<form method="post" name="expense" enctype="multipart/form-data" onsubmit="return validateForm()">

  <div class="form-section">
    <div class="form-row">
      <span class="form-label">Namn</span>
      <span>{{ session.name }}</span>
    </div>
    <div class="form-row">
      <span class="form-label">Epost</span>
      <span>{{ session.email }}</span>
    </div>
    <div class="form-row">
      <label class="form-label" for="date">Datum</label>
      <input id="date" name="date" type="date" required value="{{ date }}"/>
    </div>
  </div>

  <hr/>

  <div class="line-items">
    <div class="line-items-header">
      <span>Konto</span>
      <span>Beskrivning</span>
      <span>Belopp</span>
    </div>

    {% for row in range(10) %}
    <div class="line-item">
      <select name="{{row}}:account" onblur="updateForm()">
        <option value="">Välj konto…</option>
        {% for account, description in accounts.items() %}
        {% if account | int %}
        <option value="{{ account }}">{{ description }} ({{ account }})</option>
        {% else %}
        <option value="{{ account }}">{{ description }}</option>
        {% endif %}
        {% endfor %}
      </select>
      <input name="{{row}}:description" type="text" onblur="updateForm()" class="description" maxlength="132"/>
      <input name="{{row}}:amount" type="text" inputmode="decimal" onblur="updateForm()" value="0.00" class="amount" pattern="{{ pattern_amount }}"/>
    </div>
    {% endfor %}

    <div class="total-row">
      <span class="total-label"><b>Totalsumma</b></span>
      <span></span>
      <span class="amount_total"><span id="total">0.00</span> kr</span>
    </div>
  </div>

  <hr/>

  <div class="form-section">
    <div class="form-row">
      <label class="form-label" for="receipts">Bifogade kvitton (PDF eller PNG)</label>
      <input id="receipts" name="receipts" type="file" required accept="image/png,image/jpeg,application/pdf" multiple/>
    </div>
    <div class="form-row">
      <label class="form-label" for="recipient_account">Kontonummer</label>
      <input id="recipient_account" name="recipient_account" type="text" value="{{ recipient_account }}" required pattern="{{ pattern_account }}"/>
    </div>
    <p class="reminder">Glöm inte clearingnummer!</p>
  </div>

  <input type="hidden" name="csrf_token" value="{{ csrf_token }}"/>

  <input class="button-4" id="submit" type="submit" value="Skicka in utläggsrapport">
  <input class="button-4" id="reset" type="reset" value="Rensa">

</form>
</body>

</html>
